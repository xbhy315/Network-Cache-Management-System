<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cache.client.ui.TabPaneController">

    <!-- 顶部工具栏：新建客户端按钮 -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color: #e8e8e8; -fx-padding: 5 10 5 10;">
            <Button text="+ New Client" onAction="#onNewTab"
                    style="-fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Network Cache Management System"
                   style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <padding>
                <Insets left="5" right="15"/>
            </padding>
        </HBox>
    </top>

    <!-- 中央：多客户端标签页 -->
    <center>
        <TabPane fx:id="clientTabPane" tabClosingPolicy="SELECTED_TAB"/>
    </center>

</BorderPane>
